await player_ready

addTrackToQueue(new Track.Youtube("https://www.youtube.com/watch?v=74U7WKiPgNk")).then(() => {
  addTrackToQueue(new Track.Raw("RMFMAXX", "https://195.150.20.243/RMFMAXXX48"))
})
